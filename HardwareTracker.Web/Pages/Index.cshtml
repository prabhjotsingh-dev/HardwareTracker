@page
@model IndexModel
@{
    ViewData["Title"] = "Live System Diagnostics";
}

<div class="dashboard-header">
    <div>
        <h1 class="dashboard-title">Live System Diagnostics</h1>
        <p class="text-secondary mb-0">Real-time hardware telemetry and health monitoring</p>
    </div>
    <div>
        <a asp-page="/Index" class="btn-refresh">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M23 4v6h-6"></path>
                <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path>
            </svg>
            Refresh Telemetry
        </a>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-warning d-flex align-items-center mb-4" role="alert" style="background: rgba(245, 158, 11, 0.15); border: 1px solid rgba(245, 158, 11, 0.4); color: #fef3c7; border-radius: 12px; padding: 1.2rem;">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-exclamation-triangle-fill flex-shrink-0 me-3" viewBox="0 0 16 16" style="color: #f59e0b;">
            <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
        </svg>
        <div>
            <h5 class="alert-heading mb-1" style="font-weight: 600;">Backend Connection Offline</h5>
            <p class="mb-0">@Model.ErrorMessage</p>
        </div>
    </div>
}
else if (Model.Summary != null)
{
    var summary = Model.Summary;
    string statusClass = summary.OverallHealth switch
    {
        "Critical" => "status-critical",
        "Warning" => "status-warning",
        _ => "status-optimal"
    };

    string memProgressClass = summary.MemoryUsagePercentage switch
    {
        > 90 => "progress-bar-critical",
        > 80 => "progress-bar-warning",
        _ => ""
    };

    <div class="glass-card mb-4" style="border-color: rgba(0, 242, 254, 0.2); background: rgba(18, 25, 38, 0.85);">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div class="d-flex align-items-center gap-3">
                <div class="@statusClass status-pill">
                    <span class="status-dot"></span>
                    @summary.OverallHealth Health
                </div>
                <span class="text-secondary" style="font-size: 0.95rem;">@summary.StatusMessage</span>
            </div>
            <div class="text-secondary" style="font-size: 0.85rem; font-family: 'JetBrains Mono', monospace;">
                LAST SYNC: @summary.LastUpdated.ToLocalTime().ToString("HH:mm:ss")
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <!-- System Overview -->
        <div class="col-md-6 col-lg-4">
            <div class="glass-card">
                <div class="card-icon-title">
                    <div class="card-icon">🖥️</div>
                    <h3 class="card-title">Host Machine</h3>
                </div>
                <div class="metric-value">@summary.MachineName</div>
                <div class="metric-label mb-3">Computer Hostname</div>
                <hr style="border-color: var(--border-color); margin: 1rem 0;" />
                <div class="d-flex justify-content-between text-secondary mb-1">
                    <span>Operating System:</span>
                    <span class="text-light font-monospace">@summary.OsVersion</span>
                </div>
            </div>
        </div>

        <!-- Processor -->
        <div class="col-md-6 col-lg-4">
            <div class="glass-card">
                <div class="card-icon-title">
                    <div class="card-icon">⚡</div>
                    <h3 class="card-title">Processor (CPU)</h3>
                </div>
                <div class="metric-value" style="font-size: 1.4rem;">@summary.ProcessorName</div>
                <div class="metric-label mb-3">Active CPU Architecture</div>
                <hr style="border-color: var(--border-color); margin: 1rem 0;" />
                <div class="d-flex justify-content-between text-secondary mb-1">
                    <span>Physical Cores:</span>
                    <span class="text-light font-monospace">@summary.PhysicalCores Cores</span>
                </div>
                <div class="d-flex justify-content-between text-secondary">
                    <span>Logical Threads:</span>
                    <span class="text-light font-monospace">@summary.LogicalCores Threads</span>
                </div>
            </div>
        </div>

        <!-- Memory -->
        <div class="col-md-12 col-lg-4">
            <div class="glass-card">
                <div class="card-icon-title">
                    <div class="card-icon">🧠</div>
                    <h3 class="card-title">Memory Allocation (RAM)</h3>
                </div>
                <div class="d-flex align-items-baseline gap-2">
                    <div class="metric-value">@summary.UsedMemoryGb GB</div>
                    <span class="text-secondary font-monospace">/ @summary.TotalMemoryGb GB Total</span>
                </div>
                <div class="metric-label">System RAM Utilization</div>
                
                <div class="custom-progress-bg mt-3">
                    <div class="custom-progress-bar @memProgressClass" style="width: @(summary.MemoryUsagePercentage)%;"></div>
                </div>
                <div class="d-flex justify-content-between text-secondary mt-2" style="font-size: 0.85rem;">
                    <span>Available: @summary.AvailableMemoryGb GB</span>
                    <span class="text-light font-monospace">@summary.MemoryUsagePercentage% Used</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Storage -->
    <div class="row g-4">
        <div class="col-12">
            <div class="glass-card">
                <div class="card-icon-title mb-3">
                    <div class="card-icon">💾</div>
                    <h3 class="card-title">Storage Subsystem & Drive Telemetry</h3>
                </div>
                <div class="row g-3">
                    @foreach (var drive in summary.Drives)
                    {
                        string driveProgressClass = drive.UsagePercentage switch
                        {
                            > 90 => "progress-bar-critical",
                            > 85 => "progress-bar-warning",
                            _ => ""
                        };

                        <div class="col-md-6 col-lg-4">
                            <div class="drive-item">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="badge bg-dark border font-monospace" style="border-color: rgba(255,255,255,0.15) !important; color: var(--accent-cyan);">@drive.Name</span>
                                        <span class="text-light font-weight-bold">@drive.Label</span>
                                    </div>
                                    <span class="badge bg-secondary text-light" style="font-size: 0.7rem;">@drive.DriveType</span>
                                </div>
                                <div class="d-flex justify-content-between text-secondary mt-3 mb-1" style="font-size: 0.85rem;">
                                    <span>Used: @drive.UsedSpaceGb GB</span>
                                    <span>Total: @drive.TotalSizeGb GB</span>
                                </div>
                                <div class="custom-progress-bg">
                                    <div class="custom-progress-bar @driveProgressClass" style="width: @(drive.UsagePercentage)%;"></div>
                                </div>
                                <div class="d-flex justify-content-between text-secondary mt-1" style="font-size: 0.8rem;">
                                    <span>Free: @drive.FreeSpaceGb GB</span>
                                    <span class="text-light font-monospace">@drive.UsagePercentage%</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-2">
        <div class="col-12 text-center">
            <a asp-page="/StorageAnalysis" class="btn-refresh" style="display: inline-flex;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <path d="M12 6v6l4 2"></path>
                </svg>
                Analyze Storage Usage
            </a>
        </div>
    </div>
}
