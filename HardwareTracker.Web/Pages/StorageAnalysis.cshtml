@page
@model StorageAnalysisModel
@{
    ViewData["Title"] = "Storage Analysis";
}

<div class="dashboard-header">
    <div>
        <h1 class="dashboard-title">Storage Analysis</h1>
        <p class="text-secondary mb-0">Detailed breakdown of what's consuming disk space by category</p>
    </div>
    <div>
        <form method="post" asp-page-handler="Refresh">
            <button type="submit" class="btn-refresh" @(Model.IsScanning ? "disabled" : "")>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M23 4v6h-6"></path>
                    <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path>
                </svg>
                @(Model.IsScanning ? "Scanning..." : "Refresh Scan")
            </button>
        </form>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-warning d-flex align-items-center mb-4" role="alert" style="background: rgba(245, 158, 11, 0.15); border: 1px solid rgba(245, 158, 11, 0.4); color: #fef3c7; border-radius: 12px; padding: 1.2rem;">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-exclamation-triangle-fill flex-shrink-0 me-3" viewBox="0 0 16 16" style="color: #f59e0b;">
            <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
        </svg>
        <div>
            <h5 class="alert-heading mb-1" style="font-weight: 600;">Error</h5>
            <p class="mb-0">@Model.ErrorMessage</p>
        </div>
    </div>
}
else if (Model.IsScanning)
{
    <div class="glass-card text-center py-5">
        <div class="mb-3">
            <div class="spinner-border" style="width: 3rem; height: 3rem; color: var(--accent-cyan);" role="status">
                <span class="visually-hidden">Scanning...</span>
            </div>
        </div>
        <h4 class="text-light">Scanning storage drives...</h4>
        <p class="text-secondary mb-0">Analyzing folder sizes and file types. This may take a moment.</p>
    </div>
}
else if (Model.StorageAnalysis is { Count: > 0 })
{
    <div class="row g-4">
        <div class="col-12">
            <div class="glass-card">
                <div class="card-icon-title mb-3">
                    <div class="card-icon">📊</div>
                    <h3 class="card-title">Storage Breakdown by Category</h3>
                </div>

                @foreach (var analysis in Model.StorageAnalysis)
                {
                    <div class="storage-analysis-drive mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h4 class="text-light fs-6 fw-semibold mb-0">
                                <span class="badge bg-dark border font-monospace me-2" style="border-color: rgba(255,255,255,0.15) !important; color: var(--accent-cyan);">@analysis.DriveName</span>
                                @analysis.TotalUsedGb GB Used · @analysis.FreeSpaceGb GB Free (of @analysis.TotalSizeGb GB)
                            </h4>
                            <span class="text-secondary font-monospace" style="font-size: 0.8rem;">
                                @analysis.Categories.Count categories
                            </span>
                        </div>

                        @if (analysis.Categories.Count > 0)
                        {
                            <div class="stacked-bar mb-3">
                                @foreach (var cat in analysis.Categories)
                                {
                                    <div class="stacked-bar-segment @cat.ColorClass"
                                         style="width: @cat.PercentageOfUsed%"
                                         title="@cat.CategoryName: @cat.TotalSizeGb GB (@cat.PercentageOfUsed%)">
                                    </div>
                                }
                            </div>

                            <div class="category-list">
                                @foreach (var cat in analysis.Categories)
                                {
                                    <div class="category-row">
                                        <div class="category-indicator @cat.ColorClass"></div>
                                        <span class="category-name">@cat.CategoryName</span>
                                        <span class="category-size">@cat.TotalSizeGb GB</span>
                                        <span class="category-pct">@cat.PercentageOfUsed%</span>
                                        <span class="category-files">@cat.FileCount.ToString("N0") files</span>
                                    </div>
                                }
                            </div>

                            <div class="text-secondary mt-2" style="font-size: 0.75rem;">
                                Last scanned: @analysis.LastScanned.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")
                            </div>
                        }
                        else
                        {
                            <div class="text-secondary py-2" style="font-size: 0.85rem;">
                                No analysis data available for this drive.
                            </div>
                        }
                    </div>

                    @if (analysis != Model.StorageAnalysis.Last())
                    {
                        <hr style="border-color: var(--border-color); margin: 1rem 0;" />
                    }
                }
            </div>
        </div>
    </div>
}
else
{
    <div class="glass-card text-center py-5">
        <p class="text-secondary mb-0">No storage analysis data available.</p>
    </div>
}
