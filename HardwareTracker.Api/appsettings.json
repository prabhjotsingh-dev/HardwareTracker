{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "CorsOrigins": [],
  "HealthThresholds": {
    "MemoryCriticalThreshold": 90.0,
    "DriveCriticalThreshold": 90.0,
    "MemoryWarningThreshold": 80.0,
    "DriveWarningThreshold": 85.0
  },
  "StorageAnalysis": {
    "CacheDurationSeconds": 60,
    "ScanTimeoutSeconds": 45
  }
}
